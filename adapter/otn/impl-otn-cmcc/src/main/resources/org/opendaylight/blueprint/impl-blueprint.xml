<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0"
           xmlns:odl="http://opendaylight.org/xmlns/blueprint/v1.0.0"
           odl:use-default-for-reference-types="true">
    <!-- 对数据操作的工具类  id:索引，interface：接口 -->
    <reference id="deviceRpcProviderService"
               interface="com.optel.tmaster.dc.general.base.action.IDeviceRpcProviderService"/>
    <bean id="cmccNetconfNodeServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.listener.CmccNetconfNodeServiceImpl"/>
    <bean id="cmccOptCfmOamServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptCfmOamServiceImpl"/>
    <bean id="cmccOptConnectionServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptConnectionServiceImpl"/>
    <bean id="cmccOptDevProtectionGroupServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptDevProtectionGroupServiceImpl"/>
    <bean id="cmccOptMeLocationServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptMeLocationServiceImpl"/>
    <bean id="cmccOptNeTimeServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptNeTimeServiceImpl"/>
    <bean id="cmccOptObjInstallationServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptObjInstallationServiceImpl"/>
    <bean id="cmccOptOtnAlarmServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptOtnAlarmServiceImpl"/>
    <bean id="cmccOptOtnClockServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptOtnClockServiceImpl"/>
    <bean id="cmccOptOtnDeviceServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptOtnDeviceServiceImpl"/>
    <bean id="cmccOptOtnDhcpServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptOtnDhcpServiceImpl"/>
    <bean id="cmccOptOtnExtDevServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptOtnExtDevServiceImpl"/>
    <bean id="cmccOptOtnFileServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptOtnFileServiceImpl"/>
    <bean id="cmccOptOtnFtpServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptOtnFtpServiceImpl"/>
    <!--<bean id="cmccOptOtnPerformanceServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptOtnPerformanceServiceImpl"/>-->
    <bean id="cmccOptOtnProtectionGroupServiceImpl"
          class="com.optel.tmaster.dc.device.impl.otn.cmcc.impl.CmccOptOtnProtectionGroupServiceImpl"/>
    <!-- 具体实现的类，id：索引名称，class：接口实现类， init-method:初始化调用的方法，
    destroy-method：销毁调用的方法 ，argument：class构造函数所需要的参数	 -->
    <bean id="cmccDeviceProvider" class="com.optel.tmaster.dc.device.impl.otn.cmcc.CmccDeviceProvider"
          init-method="init" destroy-method="close">
        <argument ref="deviceRpcProviderService"/>
        <argument>
            <list>
                <ref component-id="cmccNetconfNodeServiceImpl"/>
                <ref component-id="cmccOptCfmOamServiceImpl"/>
                <ref component-id="cmccOptConnectionServiceImpl"/>
                <ref component-id="cmccOptDevProtectionGroupServiceImpl"/>
                <ref component-id="cmccOptMeLocationServiceImpl"/>
                <ref component-id="cmccOptNeTimeServiceImpl"/>
                <ref component-id="cmccOptObjInstallationServiceImpl"/>
                <ref component-id="cmccOptOtnAlarmServiceImpl"/>
                <ref component-id="cmccOptOtnClockServiceImpl"/>
                <ref component-id="cmccOptOtnDeviceServiceImpl"/>
                <ref component-id="cmccOptOtnDhcpServiceImpl"/>
                <ref component-id="cmccOptOtnExtDevServiceImpl"/>
                <ref component-id="cmccOptOtnFileServiceImpl"/>
                <ref component-id="cmccOptOtnFtpServiceImpl"/>
<!--                <ref component-id="cmccOptOtnPerformanceServiceImpl"/>-->
                <ref component-id="cmccOptOtnProtectionGroupServiceImpl"/>
            </list>
        </argument>

    </bean>

    <!-- 默认不加测试数据，对于发布版本不需要测试数据。开发环境需要使用则自己打开 -->
    <!--    <bean id="testData" class="com.optel.tmaster.dc.device.impl.otn.cmcc.test.TestData">-->
    <!--        <argument ref="dataBroker"/>-->
    <!--    </bean>-->

</blueprint>
