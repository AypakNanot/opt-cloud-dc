        </description>
        <reference>
            <text/>
        </reference>
    </typedef>
    <typedef name="pm-rpc-type">
        <type name="enumeration">
            <enum name="CURRENT">
                <description>
                    <text>the performance of current</text>
                </description>
            </enum>
            <enum name="HISTORY">
                <description>
                    <text>the performance of history</text>
                </description>
            </enum>
        </type>
        <description>
            <text>type of get pm rpc</text>
        </description>
        <reference>
            <text/>
        </reference>
