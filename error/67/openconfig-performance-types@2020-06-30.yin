<?xml version="1.0" encoding="utf-8"?>
<module xmlns="urn:ietf:params:xml:ns:yang:yin:1" xmlns:oc-performance-types="http://openconfig.net/yang/performance/types" xmlns:oc-ext="http://openconfig.net/yang/openconfig-ext" name="openconfig-performance-types">
    <yang-version value="1"/>
    <namespace uri="http://openconfig.net/yang/performance/types"/>
    <prefix value="oc-performance-types"/>
    <import module="openconfig-extensions">
        <prefix value="oc-ext"/>
    </import>
    <organization>
        <text>OpenConfig working group</text>
    </organization>
    <contact>
        <text>OpenConfig working group
www.openconfig.net</text>
    </contact>
    <description>
        <text>This module defines data types (e.g., YANG identities)
to support the OpenConfig perfomance model.</text>
    </description>
    <oc-ext:openconfig-version semver="1.0.0"/>
    <revision date="2020-06-30">
        <description>
            <text>Moved performance identities into separate types module</text>
        </description>
        <reference>
            <text>1.0.0</text>
        </reference>
    </revision>
