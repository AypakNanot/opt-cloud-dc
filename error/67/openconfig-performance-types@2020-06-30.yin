    <typedef name="pm-granularity-type">
        <type name="enumeration">
            <enum name="15MIN">
                <value value="0"/>
                <description>
                    <text>15min granularity</text>
                </description>
            </enum>
            <enum name="24H">
                <value value="1"/>
                <description>
                    <text>24h granularity</text>
                </description>
            </enum>
        </type>
        <default value="15MIN"/>
        <description>
            <text>Granularity of performance data</text>
        </description>
    </typedef>
