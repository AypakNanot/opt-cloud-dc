    <typedef name="pm-value-scope">
        <type name="enumeration">
            <enum name="INSTANT-AVG-MIN-MAX">
                <description>
                    <text>report all pm data</text>
                </description>
            </enum>
            <enum name="INSTANT">
                <description>
                    <text>only report instant data</text>
                </description>
            </enum>
        </type>
        <description>
            <text>Value scope of pm data</text>
        </description>
        <reference>
            <text/>
        </reference>
    </typedef>
    <typedef name="pm-rpc-result">
        <type name="enumeration">
            <enum name="SUCCESS">
                <description>
                    <text>The RPC action is success</text>
                </description>
            </enum>
            <enum name="FAIL">
                <description>
                    <text>The RPC action is fail</text>
                </description>
            </enum>
        </type>
        <description>
            <text>result of rpc</text>
        </description>
        <reference>
            <text/>
        </reference>
    </typedef>
    <typedef name="history-pm-type">
        <type name="enumeration">
            <enum name="RECORDS">
                <description>
                    <text>Reference records type of history performance</text>
                </description>
            </enum>
            <enum name="TIME">
                <description>
                    <text>Reference time type of history performance</text>
                </description>
            </enum>
        </type>
        <description>
